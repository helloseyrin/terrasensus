{
  "expo": {
    "name": "TerraSensus",
    "slug": "terrasensus",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a3a2a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.terrasensus.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a3a2a"
      },
      "package": "com.terrasensus.app"
    },
    "scheme": "terrasensus",
    "plugins": [
      "expo-router",
      "expo-camera"
    ]
  }
}
